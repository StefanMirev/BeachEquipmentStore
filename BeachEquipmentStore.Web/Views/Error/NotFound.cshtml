@{
    ViewData["Title"] = "Страницата не е намерена";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-file-earmark-x-fill text-warning" style="font-size: 4rem;"></i>
                    </div>
                    <h1 class="h3 mb-2">404 - Страницата не е намерена</h1>
                    <p class="text-muted mb-4">Страницата, която търсите, не съществува или е преместена.</p>

                    <div class="d-flex gap-2 justify-content-center">
                        <a href="/" class="btn btn-primary">Към началото</a>
                        <button type="button" id="goBackBtn" class="btn btn-outline-secondary">Назад</button>
                    </div>

                    <hr class="my-4" />

                    <p class="small text-muted mb-0">
                        Ако смятате, че това е грешка, пишете ни на
                        <a href="mailto:support@beachequipmentstore.com?subject=404%20Not%20Found%20Issue">support@beachequipmentstore.com</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/not-found.js" asp-append-version="true"></script>
}
