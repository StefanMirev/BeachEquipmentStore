@model RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-3">@ViewData["Title"]</h2>
        <hr />
        <form id="registerForm" method="post" asp-action="Register">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row mb-3">
                <div class="col">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" autocomplete="tel" inputmode="tel" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group has-validation">
                    <input asp-for="Password" class="form-control" autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary" data-password-toggle="Password" tabindex="-1" aria-label="Покажи паролата">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div id="passwordHint" class="form-text">Минимум 10 символа, главна буква, малка буква, цифра и специален символ.</div>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="input-group has-validation">
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary" data-password-toggle="ConfirmPassword" tabindex="-1" aria-label="Покажи паролата">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Регистрирай се</button>
            @Html.AntiForgeryToken()
        </form>

        <div class="mt-3">
            <a asp-controller="Auth" asp-action="Login">Вече имате акаунт? Влезте</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/registration-validation.js" asp-append-version="true"></script>
}