@if (TempData.ContainsKey("Message") || TempData.ContainsKey("ErrorMessage"))
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
        @if (TempData.ContainsKey("Message"))
        {
            <div class="toast align-items-center bg-success text-white border-0"
                 role="alert" aria-live="polite" aria-atomic="true"
                 data-bs-autohide="true" data-bs-delay="3500">
                <div class="d-flex">
                    <div class="toast-body fw-semibold">@TempData["Message"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData.ContainsKey("ErrorMessage"))
        {
            <div class="toast align-items-center bg-danger text-white border-0"
                 role="alert" aria-live="assertive" aria-atomic="true"
                 data-bs-autohide="false">
                <div class="d-flex">
                    <div class="toast-body fw-semibold">@TempData["ErrorMessage"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>
}
