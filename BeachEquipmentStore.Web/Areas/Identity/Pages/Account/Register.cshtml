@page "/Register"
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}
<h1 class="text-center">@ViewData["Title"]</h1>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <h2 class="text-center">Създайте своя профил!</h2>
                <hr />
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.FirstName" class="form-control" placeholder="Име" aria-required="true">
                            <label asp-for="Input.FirstName"></label>
                        </div>
                        <span asp-validation-for="Input.FirstName" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.LastName" class="form-control" placeholder="Фамилия" aria-required="true">
                            <label asp-for="Input.LastName"></label>
                        </div>
                        <span asp-validation-for="Input.LastName" class="text-danger small d-block mt-1"></span>
                    </div>
                </div>

                <div class="form-floating mt-3">
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Телефон" aria-required="true">
                    <label asp-for="Input.PhoneNumber"></label>
                </div>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small d-block mt-1"></span>

                <div class="form-floating mt-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="Имейл" autocomplete="username" aria-required="true" />
                    <label asp-for="Input.Email"></label>
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>

                <div class="form-floating mt-3">
                    <input asp-for="Input.Password" class="form-control" placeholder="Парола" autocomplete="new-password" aria-required="true" />
                    <label asp-for="Input.Password"></label>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>

                <div class="form-floating mt-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Потвърди парола" autocomplete="new-password" aria-required="true" />
                    <label asp-for="Input.ConfirmPassword"></label>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-1"></span>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary mt-4 mb-2">Регистрация</button>

                <p class="text-center">
                    <span>Имаш профил? </span>
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary text-decoration-underline">Влез в своя профил!</a>
                </p>

                @Html.AntiForgeryToken()
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/registration-validation.js" asp-append-version="true"></script>
}