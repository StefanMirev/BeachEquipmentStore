@model List<UserViewModel>

@{
    ViewBag.Title = "Направи админ";
}

<h2>Направи админ</h2>

<table>
    <thead>
        <tr>
            <th>Е-поща</th>
            <th>Име</th>
            <th>Фамилия</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>
                    <form asp-controller="User" asp-action="UpdateUserRole" method="post" style="display:inline;">
                        <input type="hidden" name="userId" value="@user.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link p-0">Направи админ</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>