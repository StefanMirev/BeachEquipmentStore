@model List<CategoryViewModel>

@{
    ViewBag.Title = "Категории";
}

<h2>@ViewBag.Title</h2>
<hr />

<div class="category-grid">
    <div class="row justify-content-evenly">
        @foreach (var category in Model)
        {
            <div class="col-md-4 mb-4" style="height: 325px; width: 325px; column-gap: 200px;">
                <a asp-controller="Product" asp-action="Catalogue" asp-route-categoryId="@category.Id" class="category-button">
                    <img src="@category.ImageUrl" alt="@category.Name">
                    <h2 class="center">@category.Name</h2>
                </a>
            </div>
        }
    </div>
</div>