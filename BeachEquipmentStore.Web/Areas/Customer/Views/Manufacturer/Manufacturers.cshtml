@model List<ManufacturerViewModel>

@{
    ViewBag.Title = "Марки";
}

<h2>@ViewBag.Title</h2>
<hr />

<div class="manufacturer-grid">
    <div class="row justify-content-evenly">
        @foreach (var manufacturer in Model)
        {
            <div class="col-md-4 mb-4" style="height: 325px; width: 325px; column-gap: 200px;">
                <a asp-controller="Product" asp-action="Catalogue" asp-route-manufacturerId="@manufacturer.Id" class="manufacturer-button">
                    <img src="@manufacturer.ImageUrl" alt="@manufacturer.Name">
                    <h2>@manufacturer.Name</h2>
                </a>
            </div>
        }
    </div>
</div>
